# Apple Wallet pass signing (see docs/plans/2025-02-24-pass-generator-design.md)
# Password to access the pass generator (required; set in Netlify env, never commit)
PASS_GENERATOR_PASSWORD=
PASSKIT_PASS_TYPE_ID=
PASSKIT_TEAM_ID=
PASSKIT_ORGANIZATION_NAME=
PASSKIT_SIGNER_CERT=
PASSKIT_SIGNER_KEY=
# PASSKIT_SIGNER_KEY_PASSPHRASE=   # optional
PASSKIT_WWDR_CERT=

# Spotify Now Playing widget on /dashboard (see scripts/get_spotify_refresh_token.js)
# Register an app at https://developer.spotify.com/dashboard, add
# http://127.0.0.1:8888/callback as a Redirect URI, then run:
#   SPOTIFY_CLIENT_ID=... SPOTIFY_CLIENT_SECRET=... node scripts/get_spotify_refresh_token.js
# Set all three in Netlify env vars (Functions scope).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# Strava Last Activity widget on /dashboard (see scripts/get_strava_refresh_token.js)
# Create an app at https://www.strava.com/settings/api with Authorization
# Callback Domain set to 127.0.0.1, then run:
#   STRAVA_CLIENT_ID=... STRAVA_CLIENT_SECRET=... node scripts/get_strava_refresh_token.js
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# GitHub Latest Commit widget on /dashboard
# Create a Personal Access Token at https://github.com/settings/tokens
# Classic token: enable the "read:user" scope to count private contributions in the heatmap.
# Without it the contributions graph will only reflect public commits.
GITHUB_TOKEN=
